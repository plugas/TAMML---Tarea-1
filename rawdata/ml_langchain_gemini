# 1. PREPARACIÓN Y LIMPIEZA DEL CONTEXTO (Riopaila Castilla)
def preparar_conocimiento_optimizado(archivo_path):
    with open(archivo_path, "r", encoding="utf-8") as f:
        texto = f.read()
    
    # Limpieza básica para ahorrar tokens y ganar velocidad
    import re
    texto = re.sub(r'http\S+', '', texto) # Quitar URLs
    texto = re.sub(r'\n\s*\n', '\n\n', texto) # Quitar espacios excesivos

    text_splitter = CharacterTextSplitter(
        separator="\n",
        chunk_size=2000,
        chunk_overlap=200
    )
    chunks = text_splitter.split_text(texto)
    return "\n".join(chunks)

# 2. CONFIGURACIÓN DEL SISTEMA Q&A CON GEMINI
def configurar_sistema_gemini(contexto):
    # Usamos Gemini 1.5 Flash (es el más rápido y gratuito)
    llm = ChatGoogleGenerativeAI(
        model="gemini-1.5-flash-8b",
        temperature=0,
        max_tokens=None
    )

    template = """
    Eres el Asistente Virtual experto de Riopaila Castilla. 
    Tu misión es responder preguntas basándote exclusivamente en el contexto proporcionado.

    CONTEXTO DE LA EMPRESA:
    {contexto_empresa}

    INSTRUCCIONES:
    - Responde en formato Markdown limpio.
    - Si la información no está en el contexto, indícalo amablemente.
    - Usa negritas para fechas y datos clave.

    Pregunta del usuario: {pregunta}
    Respuesta:
    """

    prompt = ChatPromptTemplate.from_template(template)
    chain = prompt | llm
    return chain

